import base64
import json
import logging
import tempfile
import mimetypes
import re
from typing import Dict, Any, Optional, List
from pydantic import BaseModel, Field
from mistralai.sdk import Mistral
from mistralai.models import UserMessage, SystemMessage
from pdf2image import convert_from_path
from datetime import datetime

from ..utils.config import config

logger = logging.getLogger(__name__)

# Definir el modelo de datos para facturas en Odoo
class InvoiceLine(BaseModel):
    name: str = Field(description="Descripción del producto o servicio")
    quantity: float = Field(description="Cantidad")
    price_unit: float = Field(description="Precio unitario")
    default_code: Optional[str] = Field(None, description="Código del producto")

class OdooInvoice(BaseModel):
    invoice_number: str = Field(description="Número de factura")
    invoice_date: str = Field(description="Fecha de la factura (formato DD/MM/YYYY)")
    due_date: Optional[str] = Field(None, description="Fecha de vencimiento (formato DD/MM/YYYY)")
    
    supplier_name: str = Field(description="Nombre del PROVEEDOR (quien emite la factura)")
    supplier_vat: Optional[str] = Field(None, description="CIF/NIF del proveedor")
    supplier_address: Optional[str] = Field(None, description="Dirección del proveedor")
    supplier_city: Optional[str] = Field(None, description="Ciudad del proveedor")
    supplier_zip: Optional[str] = Field(None, description="Código postal del proveedor")
    supplier_email: Optional[str] = Field(None, description="Email del proveedor")
    supplier_phone: Optional[str] = Field(None, description="Teléfono del proveedor")
    
    customer_name: Optional[str] = Field(None, description="Nombre del CLIENTE (quien recibe la factura)")
    customer_vat: Optional[str] = Field(None, description="CIF/NIF del cliente")
    
    total_amount: float = Field(description="Importe total con impuestos")
    tax_amount: Optional[float] = Field(None, description="Importe de impuestos")
    subtotal: Optional[float] = Field(None, description="Subtotal sin impuestos")
    
    payment_terms: Optional[str] = Field(None, description="Condiciones de pago")
    customer_order_ref: Optional[str] = Field(None, description="Referencia de pedido del cliente")
    
    line_items: list[InvoiceLine] = Field(description="Líneas de productos/servicios")

class MistralFreeOCRService:
    """
    Servicio para integración con Mistral OCR API gratuita
    Utiliza Document Annotation para extraer datos estructurados de facturas
    Integra agentes de Mistral para análisis avanzado de facturas
    """
    
    def __init__(self):
        self.api_key = config.MISTRAL_API_KEY
        if not self.api_key:
            raise ValueError("MISTRAL_API_KEY no está configurada en las variables de entorno")
        
        self.client = Mistral(api_key=self.api_key)
        self.ocr_model = "mistral-ocr-latest"
        self.chat_model = "mistral-large-latest"  # Modelo para chat
    
    def get_supported_formats(self) -> list[str]:
        """
        Devuelve los formatos de archivo soportados
        """
        return ['.pdf', '.jpg', '.jpeg', '.png']
    
    def validate_file_size(self, file_path: str) -> bool:
        """
        Valida que el archivo no exceda el límite de tamaño (50MB)
        """
        max_size_mb = 50
        file_size_mb = os.path.getsize(file_path) / (1024 * 1024)
        return file_size_mb <= max_size_mb
    
    def process_invoice_file(self, file_path: str) -> Dict[str, Any]:
        """
        Procesa un archivo de factura (PDF o imagen) y extrae datos estructurados
        usando la API gratuita de Mistral Document Annotation y luego mejora los resultados
        con un agente especializado en análisis de facturas
        """
        try:
            # Validar tamaño de archivo
            if not self.validate_file_size(file_path):
                return {
                    'success': False,
                    'error': "El archivo excede el límite de 50MB"
                }
            
            # Detectar tipo de archivo
            mime_type = mimetypes.guess_type(file_path)[0] or 'application/octet-stream'
            
            # Si es un PDF, convertirlo a imagen
            if mime_type == 'application/pdf':
                logger.info(f"Convirtiendo PDF a imagen: {file_path}")
                return self._process_pdf_file(file_path)
            else:
                # Si es una imagen, procesarla directamente
                return self._process_image_file(file_path)
        
        except Exception as e:
            logger.error(f"Error procesando factura con Mistral Free OCR: {e}")
            return {
                'success': False,
                'error': str(e)
            }
            
    def _process_image_file(self, file_path: str) -> Dict[str, Any]:
        """
        Procesa un archivo de imagen directamente con la API de Mistral OCR
        """
        try:
            # Leer archivo y convertir a base64
            with open(file_path, "rb") as f:
                file_content = f.read()
            
            file_b64 = base64.b64encode(file_content).decode('utf-8')
            mime_type = mimetypes.guess_type(file_path)[0] or 'image/jpeg'
            
            # Formato correcto para la versión 1.9.1 de mistralai
            # La API ha cambiado, ahora usamos el formato JSON directamente
            # Crear un esquema JSON para la extracción de datos de la factura
            schema = {
                "type": "object",
                "properties": {
                    "invoice_number": {"type": "string", "description": "Número de factura"},
                    "invoice_date": {"type": "string", "description": "Fecha de factura en formato DD/MM/YYYY"},
                    "supplier_name": {"type": "string", "description": "Nombre del proveedor"},
                    "supplier_vat": {"type": "string", "description": "NIF/CIF del proveedor"},
                    "total_amount": {"type": "number", "description": "Importe total de la factura"},
                    "tax_amount": {"type": "number", "description": "Importe de IVA"},
                    "line_items": {
                        "type": "array",
                        "items": {
                            "type": "object",
                            "properties": {
                                "name": {"type": "string", "description": "Descripción del producto o servicio"},
                                "quantity": {"type": "number", "description": "Cantidad"},
                                "price_unit": {"type": "number", "description": "Precio unitario"},
                                "default_code": {"type": "string", "description": "Código del producto"}
                            },
                            "required": ["name", "quantity", "price_unit"]
                        },
                        "description": "Líneas de productos/servicios"
                    }
                },
                "required": ["invoice_number", "invoice_date", "supplier_name", "total_amount", "line_items"]
            }
            
            # Importar ImageURLChunk para el formato correcto
            from mistralai import ImageURLChunk
            
            # Crear el documento con el formato correcto para imágenes
            document = ImageURLChunk(
                image_url=f"data:{mime_type};base64,{file_b64}"
            )
            
            # Usar el método process() del objeto ocr con el formato correcto
            # Usar el formato correcto para document_annotation_format (pasar el esquema directamente)
            response = self.client.ocr.process(
                model=self.ocr_model,
                document=document,
                document_annotation_format=schema
            )
            
            # En la versión 1.9.1, la respuesta del OCR tiene una estructura específica
            # Extraer datos de la respuesta de manera segura
            try:
                invoice_data = {}
                
                # Si hay document_annotation (respuesta estructurada según el esquema)
                if hasattr(response, 'document_annotation') and response.document_annotation:
                    logger.info("Usando document_annotation para datos estructurados")
                    invoice_data = response.document_annotation
                # Si hay páginas con texto markdown
                elif hasattr(response, 'pages') and len(response.pages) > 0:
                    logger.info("Extrayendo texto markdown de las páginas")
                    # Extraer el texto markdown de todas las páginas
                    markdown_text = "\n".join([page.markdown for page in response.pages if hasattr(page, 'markdown')])
                    
                    # Extraer datos básicos del texto usando heurísticas
                    invoice_data = self._extract_invoice_data_from_text(markdown_text)
                    
                    # Guardar el texto completo para referencia
                    invoice_data["text"] = markdown_text
                else:
                    logger.warning("No se encontraron datos estructurados ni texto en la respuesta")
                    # Crear un diccionario con información básica de la respuesta
                    invoice_data = {
                        "model": getattr(response, 'model', 'unknown'),
                        "error": "No se pudieron extraer datos estructurados"
                    }
            except Exception as e:
                logger.error(f"Error procesando respuesta OCR: {e}")
                invoice_data = {"error": str(e)}
                
            # Obtener el texto OCR completo para procesamiento con agente
            ocr_text = self._extract_ocr_text(response)
            
            # Procesar con agente especializado en facturas para mejorar los datos
            enhanced_data = self._process_with_invoice_agent(ocr_text, invoice_data)
            
            return {
                'success': True,
                'invoice_data': enhanced_data,
                'confidence': 'high',
                'document_type': 'invoice'
            }
            
        except Exception as e:
            logger.error(f"Error procesando factura con Mistral Free OCR: {e}")
            return {
                'success': False,
                'error': str(e)
            }

    def _extract_invoice_data_from_text(self, text: str) -> Dict[str, Any]:
        """Extrae datos estructurados de factura desde texto markdown"""
        lines = text.split('\n')
        invoice_data = {
            "invoice_number": "",
            "invoice_date": "",
            "supplier_name": "",
            "supplier_vat": "",  # Añadido para NIF/CIF
            "total_amount": 0.0,
            "tax_amount": 0.0,   # Añadido para IVA
            "subtotal": 0.0,     # Añadido para base imponible
            "line_items": []
        }
        # Buscar número de factura específicamente para facturas Alfadyser (formato 25FVR-0012334)
        for line in lines:
            matches = re.findall(r'\b(\d+[A-Z]+-\d+)\b', line)
            if matches:
                invoice_data["invoice_number"] = matches[0].strip()
                break
        # Si no se encontró con el patrón específico, buscar en tablas
        if not invoice_data["invoice_number"]:
            for i, line in enumerate(lines):
                if '|  Número factura | Fecha | Cód. Cliente  |' in line and i + 2 < len(lines):
                    data_line = lines[i + 2]
                    if data_line.startswith('|'):
                        cells = [cell.strip() for cell in data_line.split('|') if cell.strip()]
                        if len(cells) >= 2:
                            invoice_data["invoice_number"] = cells[0].strip()
                            if len(cells) >= 3:
                                # Convertir fecha al formato ISO (YYYY-MM-DD)
                                date_str = cells[1].strip()
                                try:
                                    for fmt in ['%d/%m/%Y', '%d-%m-%Y', '%d/%m/%y', '%d-%m-%y']:
                                        try:
                                            date_obj = datetime.strptime(date_str, fmt)
                                            invoice_data["invoice_date"] = date_obj.strftime('%Y-%m-%d')
                                            break
                                        except ValueError:
                                            continue
                                except Exception:
                                    invoice_data["invoice_date"] = date_str
                            break
        # Buscar NIF/CIF del proveedor (formato común: letra + números)
        for line in lines:
            vat_matches = re.findall(r'\b[A-Z0-9]{1}[-\s]?\d{7,8}[-\s]?[A-Z0-9]{1}\b', line, re.IGNORECASE)
            if vat_matches:
                invoice_data["supplier_vat"] = vat_matches[0].replace(' ', '').replace('-', '')
                break
            if "NIF:" in line or "CIF:" in line or "N.I.F.:" in line:
                vat_matches = re.findall(r'(?:NIF|CIF|N\.I\.F\.):?\s*([A-Z0-9]{1}[-\s]?\d{7,8}[-\s]?[A-Z0-9]{1})', line, re.IGNORECASE)
                if vat_matches:
                    invoice_data["supplier_vat"] = vat_matches[0].replace(' ', '').replace('-', '')
                    break
        # Buscar importe total con patrones mejorados
        total_patterns = [
            r'Total[:\s]*([\d.,]+)\s*[€$]',
            r'TOTAL[:\s]*([\d.,]+)\s*[€$]',
            r'([\d.,]+)\s*[€$]\s*Total',
            r'([\d.,]+)\s*EUR',
            r'Total:\s*([\d.,]+)',
            r'TOTAL FACTURA:?\s*([\d.,]+)',
            r'Importe total:?\s*([\d.,]+)'
        ]
        for line in lines:
            if "Total" in line or "TOTAL" in line:
                logger.info(f"Encontrada línea con Total: {line}")
                for pattern in total_patterns:
                    matches = re.findall(pattern, line, re.IGNORECASE)
                    if matches:
                        amount_str = matches[0].replace('.', '').replace(',', '.')
                        try:
                            invoice_data["total_amount"] = float(amount_str)
                            logger.info(f"Importe total extraído: {invoice_data['total_amount']}")
                            break
                        except ValueError:
                            continue
        table_start = False
        table_headers = []
        product_lines = []
        for line in lines:
            if line.startswith('|') and ('---' in line or 'Descripción' in line or 'Producto' in line):
                table_start = True
                continue
            if table_start and line.startswith('|'):
                if not table_headers:
                    table_headers = [h.strip().lower() for h in line.split('|') if h.strip()]
                    logger.info(f"Encabezados de tabla detectados: {table_headers}")
                else:
                    cells = [c.strip() for c in line.split('|') if c]
                    if len(cells) >= 2:
                        product_line = {
                            "name": cells[0] if cells else "Producto sin descripción",
                            "quantity": 1.0,
                            "price_unit": 0.0,
                            "default_code": ""
                        }
                        for i, cell in enumerate(cells):
                            if i < len(table_headers):
                                header = table_headers[i]
                                if 'cantidad' in header or 'uds' in header or 'unid' in header:
                                    try:
                                        qty_match = re.search(r'([\d.,]+)', cell)
                                        if qty_match:
                                            product_line["quantity"] = float(qty_match.group(1).replace(',', '.'))
                                    except ValueError:
                                        pass
                                if 'precio' in header and 'total' not in header:
                                    try:
                                        price_match = re.search(r'([\d.,]+) ', cell)
                                        if price_match:
                                            product_line["price_unit"] = float(price_match.group(1).replace('.', '').replace(',', '.'))
                                    except ValueError:
                                        pass
                                if 'código' in header or 'referencia' in header or 'ref' in header:
                                    product_line["default_code"] = cell.strip()
                        if product_line["quantity"] == 1.0 or product_line["price_unit"] == 0.0:
                            for cell in cells:
                                if product_line["quantity"] == 1.0:
                                    qty_match = re.search(r'^([\d.,]+)$',cell)
    
    def _extract_ocr_text(self, response) -> str:
        """
        Extrae el texto OCR completo de la respuesta para procesamiento con agentes
        """
        try:
            # En la versión 1.9.1 del SDK, la respuesta tiene páginas con texto markdown
            if hasattr(response, 'pages') and len(response.pages) > 0:
                # Extraer el texto markdown de todas las páginas
                return "\n".join([page.markdown for page in response.pages if hasattr(page, 'markdown')])
            # Verificar otros formatos de respuesta
            elif hasattr(response, 'text'):
                return response.text
            elif hasattr(response, 'choices') and len(response.choices) > 0:
                return response.choices[0].message.content
            else:
                # Último recurso: convertir el objeto a string
                return str(response)
        except Exception as e:
            logger.error(f"Error extrayendo texto OCR: {e}")
            return ""
    
    def _process_with_invoice_agent(self, ocr_text: str, initial_data: Dict[str, Any]) -> Dict[str, Any]:
        """
        Procesa el texto OCR con el modelo de chat de Mistral para mejorar y completar los datos extraídos
        """
        try:
            logger.info("Procesando factura con modelo de chat de Mistral")
            
            # Preparar el prompt para el modelo con los datos iniciales y el texto OCR
            prompt = f"""
            Eres un experto en análisis de facturas. Analiza esta factura extraída por OCR y mejora los datos.
            
            TEXTO OCR DE LA FACTURA:
            {ocr_text[:3000]}  # Limitamos para evitar tokens excesivos
            
            DATOS INICIALES EXTRAÍDOS:
            {json.dumps(initial_data, indent=2, ensure_ascii=False)}
            
            Proporciona una versión mejorada y corregida de los datos en formato JSON. Completa todos los campos
            posibles basándote en el texto OCR. Si no puedes determinar un valor, mantén el valor original.
            Asegúrate de que el formato JSON sea válido.
            """
            
            # Crear mensajes para el chat usando SystemMessage y UserMessage
            messages = [
                SystemMessage(content="Eres un experto en análisis de facturas y extracción de datos estructurados."),
                UserMessage(content=prompt)
            ]
            
            # Llamar al modelo de chat con la API v1.9.1
            response = self.client.chat(
                model=self.chat_model,
                messages=messages
            )
            
            # Extraer respuesta del modelo
            content = response.choices[0].message.content
            
            # Extraer JSON de la respuesta
            enhanced_data = self._extract_json_from_text(content)
            
            if enhanced_data:
                logger.info("Datos de factura mejorados con modelo de chat")
                return enhanced_data
            else:
                logger.warning("No se pudo extraer JSON válido de la respuesta del modelo de chat")
                return initial_data
                
        except Exception as e:
            logger.error(f"Error procesando con modelo de chat: {e}")
            return initial_data
    
    # El método _create_invoice_analysis_agent ha sido eliminado ya que ahora usamos el modelo de chat directamente
    
    def _process_pdf_file(self, file_path: str) -> Dict[str, Any]:
        """
        Procesa un archivo PDF directamente con la API de Mistral OCR
        """
        try:
            logger.info(f"Procesando PDF directamente con Mistral OCR: {file_path}")
            
            # Leer el archivo PDF y convertirlo a base64
            with open(file_path, "rb") as pdf_file:
                file_b64 = base64.b64encode(pdf_file.read()).decode('utf-8')
            
            # Importar DocumentURLChunk para el formato correcto
            from mistralai import DocumentURLChunk
            
            # Crear un esquema JSON para la extracción de datos de la factura
            schema = {
                "type": "object",
                "properties": {
                    "invoice_number": {"type": "string", "description": "Número de factura"},
                    "invoice_date": {"type": "string", "description": "Fecha de factura en formato DD/MM/YYYY"},
                    "supplier_name": {"type": "string", "description": "Nombre del proveedor"},
                    "supplier_vat": {"type": "string", "description": "NIF/CIF del proveedor"},
                    "total_amount": {"type": "number", "description": "Importe total de la factura"},
                    "tax_amount": {"type": "number", "description": "Importe de IVA"},
                    "line_items": {
                        "type": "array",
                        "items": {
                            "type": "object",
                            "properties": {
                                "name": {"type": "string", "description": "Descripción del producto o servicio"},
                                "quantity": {"type": "number", "description": "Cantidad"},
                                "price_unit": {"type": "number", "description": "Precio unitario"},
                                "default_code": {"type": "string", "description": "Código del producto"}
                            },
                            "required": ["name", "quantity", "price_unit"]
                        },
                        "description": "Líneas de productos/servicios"
                    }
                },
                "required": ["invoice_number", "invoice_date", "supplier_name", "total_amount", "line_items"]
            }
            
            # Crear el documento con el formato correcto para PDFs
            document = DocumentURLChunk(
                document_url=f"data:application/pdf;base64,{file_b64}"
            )
            
            # Usar el método process() del objeto ocr con el formato correcto
            # Usar el formato correcto para document_annotation_format (pasar el esquema directamente)
            response = self.client.ocr.process(
                model=self.ocr_model,
                document=document,
                document_annotation_format=schema
            )
            
            # En la versión 1.9.1, la respuesta del OCR tiene una estructura específica
            # Extraer datos de la respuesta de manera segura
            try:
                invoice_data = {}
                
                # Si hay document_annotation (respuesta estructurada según el esquema)
                if hasattr(response, 'document_annotation') and response.document_annotation:
                    logger.info("Usando document_annotation para datos estructurados")
                    invoice_data = response.document_annotation
                # Si hay páginas con texto markdown
                elif hasattr(response, 'pages') and len(response.pages) > 0:
                    logger.info("Extrayendo texto markdown de las páginas")
                    # Extraer el texto markdown de todas las páginas
                    markdown_text = "\n".join([page.markdown for page in response.pages if hasattr(page, 'markdown')])
                    
                    # Extraer datos básicos del texto usando heurísticas
                    invoice_data = self._extract_invoice_data_from_text(markdown_text)
                    
                    # Guardar el texto completo para referencia
                    invoice_data["text"] = markdown_text
                else:
                    logger.warning("No se encontraron datos estructurados ni texto en la respuesta")
                    # Crear un diccionario con información básica de la respuesta
                    invoice_data = {
                        "model": getattr(response, 'model', 'unknown'),
                        "error": "No se pudieron extraer datos estructurados"
                    }
            except Exception as e:
                logger.error(f"Error procesando respuesta OCR: {e}")
                invoice_data = {"error": str(e)}
                
            # Obtener el texto OCR completo para procesamiento con agente
            ocr_text = self._extract_ocr_text(response)
            
            # Procesar con agente especializado en facturas para mejorar los datos
            enhanced_data = self._process_with_invoice_agent(ocr_text, invoice_data)
            
            return {
                'success': True,
                'invoice_data': enhanced_data,
                'ocr_text': ocr_text
            }
                
        except Exception as e:
            logger.error(f"Error procesando PDF con Mistral OCR: {e}")
            return {
                'success': False,
                'error': f"Error procesando PDF con Mistral OCR: {str(e)}"
            }
    
    def _extract_json_from_text(self, text: str) -> Dict[str, Any]:
        """
        Extrae un objeto JSON de un texto que puede contener explicaciones adicionales
        """
        try:
            # Buscar contenido entre llaves {} que podría ser JSON
            json_pattern = r'\{[\s\S]*\}'
            json_matches = re.findall(json_pattern, text)
            
            if json_matches:
                # Intentar parsear cada coincidencia como JSON
                for json_str in json_matches:
                    try:
                        return json.loads(json_str)
                    except:
                        continue
            
            # Si no se encontró JSON válido, intentar parsear todo el texto
            return json.loads(text)
        except Exception as e:
            logger.warning(f"No se pudo extraer JSON de la respuesta: {e}")
            return {}

# Instancia global del servicio (lazy loading)
_mistral_free_ocr_service = None

def get_mistral_free_ocr_service():
    return _mistral_free_ocr_service
