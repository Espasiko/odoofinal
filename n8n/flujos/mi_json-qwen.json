        "genericAuthType": "httpHeaderAuth",
        "sendBody": true,
        "bodyParameters": {
          "parameters": [
            {
              "name": "jsonrpc",
              "value": "2.0"
            },
            {
              "name": "method",
              "value": "call"
            },
            {
              "name": "params",
              "value": "={{ { \"service\": \"object\", \"method\": \"execute_kw\", \"args\": [ \"fresh_odoo_db\", $node[\"Set Variables\"].json[\"odooUid\"], $node[\"Set Variables\"].json[\"odooPassword\"], \"rgpd.request\", \"create\", [{ \"partner_id\": $json[\"partner_id\"], \"request_type\": $json[\"tipo_solicitud\"], \"request_date\": $now, \"state\": \"done\", \"notes\": $json[\"descripcion\"] }] ] } }}"
            },
            {
              "name": "id",
              "value": "1"
            }
          ]
        },
        "options": {}
