            },
            {
              "name": "method",
              "value": "call"
            },
            {
              "name": "params",
              "value": "={{ { \"service\": \"object\", \"method\": \"execute_kw\", \"args\": [ \"fresh_odoo_db\", $node[\"Set Variables\"].json[\"odooUid\"], $node[\"Set Variables\"].json[\"odooPassword\"], \"res.partner\", \"search_read\", [[\"email\", \"=\", $json[\"email\"]]], {\"fields\": [\"name\", \"email\", \"phone\", \"vat\", \"street\", \"city\", \"zip\", \"country_id\"]} ] } }}"
            },
            {
              "name": "id",
              "value": "1"
            }
          ]
        },
        "options": {}
      },
