              "name": "params",
              "value": "={{ { \"service\": \"object\", \"method\": \"execute_kw\", \"args\": [ \"fresh_odoo_db\", $node[\"Set Variables\"].json[\"odooUid\"], $node[\"Set Variables\"].json[\"odooPassword\"], \"res.partner\", \"write\", [[$json[\"partner_id\"]], $json[\"datos_actualizados\"]] ] } }}"
