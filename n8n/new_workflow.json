{
  "name": "Asistente Odoo 18 con Groq",
  "nodes": [
    {
      "parameters": {
        "options": {}
      },
      "name": "When chat message received",
      "type": "@n8n/n8n-nodes-langchain.chatTrigger",
      "typeVersion": 1.2,
      "position": [300, 300]
    },
    {
      "parameters": {
        "model": "llama-3.1-8b-instant",
        "baseUrl": "https://api.groq.com/openai/v1",
        "authentication": "predefinedCredentialType",
        "credentialType": "groqApi",
        "options": {
          "maxTokens": 1024,
          "temperature": 0.7
        }
      },
      "name": "Groq LLM",
      "type": "@n8n/n8n-nodes-langchain.lmChatOpenAi",
      "typeVersion": 1.2,
      "position": [700, 500],
      "credentials": {
        "groqApi": {
          "id": "1rpESnsAGutidKmH",
          "name": "Groq API Credentials"
        }
      }
    },
    {
      "parameters": {
        "systemMessage": "Eres un asistente experto en Odoo 18 y procesamiento de facturas. Responde en español de manera clara y concisa. Ayuda con preguntas sobre:\n\n1. Configuración de Odoo 18\n2. Procesamiento OCR de facturas\n3. Integración con n8n y FastAPI\n4. Validación de datos de facturas\n5. Automatización de flujos de trabajo\n\nSi no conoces la respuesta, indícalo claramente y sugiere dónde buscar más información.",
        "options": {
          "memory": {
            "type": "simple"
          }
        }
      },
      "name": "AI Agent",
      "type": "@n8n/n8n-nodes-langchain.agent",
      "typeVersion": 2.2,
      "position": [500, 300]
    }
  ],
  "connections": {
    "When chat message received": {
      "main": [
        [
          {
            "node": "AI Agent",
            "type": "main",
            "index": 0
          }
        ]
      ]
    },
    "AI Agent": {
      "llm": [
        [
          {
            "node": "Groq LLM",
            "type": "main",
            "index": 0
          }
        ]
      ]
    }
  },
  "settings": {
    "executionOrder": "v1",
    "saveDataErrorExecution": "all",
    "saveDataSuccessExecution": "all",
    "saveManualExecutions": true,
    "saveExecutionProgress": true,
    "timezone": "Europe/Madrid"
  }
}
